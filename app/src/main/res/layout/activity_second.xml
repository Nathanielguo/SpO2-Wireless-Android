<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    tools:context=".SecondActivity">

    <!-- 顶部标题与连接状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/monitor_title"
            android:textColor="@color/colorTextPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/status_dot_disconnected" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_disconnected"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- 四路波形 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- 直流分量 660nm -->
            <LinearLayout
                style="@style/CardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_dc"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="@string/label_660"
                    android:textColor="@color/colorWave660"
                    android:textSize="11sp" />

                <com.example.natha.myapplication000.SpO2
                    android:id="@+id/ECGView03"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    app:BackLineColor="@color/colorWaveGrid"
                    app:PointerLineColor="@color/colorWaveGrid" />

            </LinearLayout>

            <!-- 直流分量 940nm -->
            <LinearLayout
                style="@style/CardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_dc"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="@string/label_940"
                    android:textColor="@color/colorWave940"
                    android:textSize="11sp" />

                <com.example.natha.myapplication000.SpO2
                    android:id="@+id/ECGView04"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    app:BackLineColor="@color/colorWaveGrid"
                    app:PointerLineColor="@color/colorWaveGrid" />

            </LinearLayout>

            <!-- 交流分量 660nm -->
            <LinearLayout
                style="@style/CardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_ac"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="@string/label_660"
                    android:textColor="@color/colorWave660"
                    android:textSize="11sp" />

                <com.example.natha.myapplication000.SpO2
                    android:id="@+id/ECGView05"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    app:BackLineColor="@color/colorWaveGrid"
                    app:PointerLineColor="@color/colorWaveGrid" />

            </LinearLayout>

            <!-- 交流分量 940nm -->
            <LinearLayout
                style="@style/CardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/label_ac"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="@string/label_940"
                    android:textColor="@color/colorWave940"
                    android:textSize="11sp" />

                <com.example.natha.myapplication000.SpO2
                    android:id="@+id/ECGView02"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    app:BackLineColor="@color/colorWaveGrid"
                    app:PointerLineColor="@color/colorWaveGrid" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 开始/停止按钮 -->
    <Button
        android:id="@+id/start"
        style="@style/PrimaryButton"
        android:layout_margin="16dp"
        android:text="@string/btn_start" />

</LinearLayout>
